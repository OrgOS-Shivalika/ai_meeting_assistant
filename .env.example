# ============================================================================
# AI Meeting Assistant — environment configuration
# Copy to .env and fill in. Lines that already have a sensible default in
# settings.py are commented out.
# ============================================================================

# ---- Database --------------------------------------------------------------
# Default points at the host-Postgres setup. Override to point at the compose
# Postgres (port 5433) or any other instance.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/meeting_ai
# DOCKER_DATABASE_URL is what the Celery worker (running inside compose) uses
# to reach Postgres. Defaults to the compose service.
# DOCKER_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/meeting_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=meeting_ai

# ---- Auth ------------------------------------------------------------------
AUTH_SECRET_KEY=change-me-in-production

# ---- Async infra (Phase 1B) -----------------------------------------------
# Toggle the meeting pipeline between in-process (false) and Celery (true).
# Compose worker forces this on.
USE_CELERY=false
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ---- Object storage (Phase 1C) --------------------------------------------
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=meeting-ai-documents
S3_REGION=us-east-1
S3_USE_PATH_STYLE=true

# ---- AI providers ----------------------------------------------------------
OPEN_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ---- Recall.ai -------------------------------------------------------------
RECALL_API_KEY=
BASE_URL=https://ap-northeast-1.recall.ai/api/v1

# ---- Google OAuth ---------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
APP_PUBLIC_URL=http://localhost:8000

# ---- CORS -----------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:8000,http://127.0.0.1:8000

# ---- Langfuse (agents_v2 tracing) -----------------------------------------
# Get these from https://cloud.langfuse.com — sign up, create a project,
# copy the two keys from Project Settings. Leave blank for local dev
# without tracing; the SDK becomes a no-op when unset.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
